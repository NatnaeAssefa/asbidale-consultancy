# =============================================================================
# Auth — switch providers without code changes
#   demo  = local testing (default)
#   imap  = cPanel / hosted email mailboxes (asbidale.com)
#   api   = your future backend auth service
# =============================================================================
AUTH_PROVIDER=imap

# Required in production (long random string)
AUTH_SESSION_SECRET=change-me-to-a-long-random-secret

# Allowed mailbox domains (comma-separated)
AUTH_ALLOWED_DOMAINS=asbidale.com

# Role mapping by email (comma-separated). Default role if unmatched:
AUTH_ROLE_DEFAULT=both
AUTH_BOTH_EMAILS=info@asbidale.com
AUTH_SPONSOR_EMAILS=
AUTH_INVESTIGATOR_EMAILS=

# --- When AUTH_PROVIDER=imap ---
IMAP_HOST=mail.asbidale.com
IMAP_PORT=993
IMAP_SECURE=true
# cPanel cert often mismatches hostname — Outlook warns then continues; Node needs this:
IMAP_TLS_REJECT_UNAUTHORIZED=false

# --- When AUTH_PROVIDER=api (future backend) ---
# AUTH_API_URL=https://api.asbidale.com
# AUTH_API_KEY=
